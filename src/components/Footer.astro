---
import { version } from "../../package.json";
const year = new Date().getFullYear();
---

<footer class="mx-auto max-w-5xl px-6 pb-12 pt-10">
  <div class="flex flex-wrap items-center justify-between gap-4 border-t border-white/10 pt-6">
    <p class="text-xs text-slate-400">
      © {year} Kaiano Levine · Twin Cities, MN
    </p>
    <div class="flex items-center gap-4">
      <span class="font-mono text-xs text-slate-600">v{version}</span>
      <span class="text-slate-700">·</span>
      <span class="font-mono text-xs text-slate-500">api.kaianolevine.com</span>
    </div>
  </div>
</footer>
