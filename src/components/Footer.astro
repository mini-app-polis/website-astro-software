---
import { version } from "../../package.json";
const year = new Date().getFullYear();
---

<footer class="mx-auto max-w-5xl px-6 pb-12 pt-10">
  <div class="grid grid-cols-3 items-center border-t border-white/10 pt-6">
    <p class="text-xs text-slate-400">
      © {year} Kaiano Levine · Twin Cities, MN
    </p>
    <p class="text-center text-xs text-slate-500">
      Live data: <span class="font-mono text-slate-200">api.kaianolevine.com</span>
    </p>
    <p class="text-right font-mono text-xs text-slate-600">
      v{version}
    </p>
  </div>
</footer>
