---
const year = new Date().getFullYear();
---

<footer class="mx-auto max-w-5xl px-6 pb-12 pt-10">
  <div class="flex flex-wrap items-center justify-between gap-4 border-t border-white/10 pt-6">
    <p class="text-xs text-slate-400">
      © {year} Kaiano Levine. Dark mode by default.
    </p>
    <p class="text-xs text-slate-500">
      Live data: <span class="font-mono text-slate-200">api.kaianolevine.com</span>
    </p>
  </div>
</footer>

