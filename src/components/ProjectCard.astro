---
export type ProjectCardProps = {
  title: string;
  description: string;
  status: string;
  link?: string;
  linkLabel?: string;
};

const { title, description, status, link, linkLabel } = Astro.props as ProjectCardProps;
const isExternal =
  !!link && (link.startsWith("http://") || link.startsWith("https://"));
const ctaLabel = linkLabel ?? (isExternal ? "GitHub" : "Open");
---

<article
  class="group flex h-full flex-col rounded-2xl border border-white/10 bg-white/[0.02] p-6 shadow-soft transition-colors hover:border-white/20"
>
  <div class="flex-1">
    <h2 class="font-display text-xl tracking-tight">{title}</h2>
    <p class="mt-2 text-sm leading-relaxed text-slate-300">{description}</p>
  </div>

  <div class="mt-4 flex items-center justify-between gap-4">
    <div class="rounded-full border border-white/10 bg-black/20 px-3 py-1">
      <span class="font-mono text-xs text-accent">{status}</span>
    </div>
    {link ? (
      <a
        href={link}
        {...isExternal ? { target: "_blank", rel: "noreferrer" } : {}}
        class="inline-flex items-center gap-2 text-sm font-medium text-slate-200 transition-colors hover:text-accent"
      >
        <span>{ctaLabel}</span>
        <span aria-hidden="true" class="font-mono">↗</span>
      </a>
    ) : null}
  </div>
</article>
