---
import YearFilter from "./YearFilter.astro";

interface Props {
  years?: number[];
  initialYear?: number;
  pageSize?: number;
}

const {
  years = [],
  initialYear = 2026,
  pageSize = 50,
} = Astro.props as Props;
---

<section
  data-sets-root
  data-initial-year={initialYear}
  data-page-size={pageSize}
  class="space-y-5"
>
  <div class="flex flex-wrap items-end justify-between gap-4">
    <div>
      <h2 class="font-display text-xl tracking-tight">Browse Sets</h2>
      <p class="mt-1 text-sm text-slate-400">
        Filter by year, then open a set for its full track list.
      </p>
    </div>
    <YearFilter years={years} selectedYear={initialYear} />
  </div>

  <div
    id="setsList"
    class="space-y-3 rounded-2xl border border-white/10 bg-white/[0.02] p-4"
  ></div>

  <div class="flex items-center justify-between gap-4">
    <p id="statusText" class="text-sm text-slate-400"></p>
    <button
      id="loadMoreBtn"
      type="button"
      class="rounded-full border border-white/10 bg-white/[0.02] px-5 py-2 text-sm font-medium text-slate-200 transition-colors hover:border-white/20 hover:text-slate-100 disabled:opacity-50"
    >
      Load more
    </button>
  </div>

  <script type="module">
    async function getSets(params = {}) {
      const BASE = document.documentElement.dataset.apiUrl || "";
      if (!BASE) return [];

      try {
        const qs = new URLSearchParams(
          Object.entries(params).map(([k, v]) => [k, String(v)]),
        ).toString();

        const baseUrl = String(BASE).replace(/\/$/, "");
        const url = `${baseUrl}/v1/sets${qs ? "?" + qs : ""}`;

        const res = await fetch(url, { cache: "no-store" });
        if (!res.ok) return [];

        const json = await res.json();
        return json?.data ?? [];
      } catch {
        return [];
      }
    }

    const root = document.querySelector("[data-sets-root]");
    if (!root) throw new Error("Sets root not found");

    const years = Array.from(root.querySelectorAll('button[data-year]')).map(
      (b) => b.getAttribute("data-year"),
    );
    void years;

    const pageSize = Number(root.getAttribute("data-page-size") ?? 50);
    const initialYear = root.getAttribute("data-initial-year");
    const listEl = root.querySelector("#setsList");
    const statusText = root.querySelector("#statusText");
    const loadMoreBtn = root.querySelector("#loadMoreBtn");
    if (!listEl || !statusText || !loadMoreBtn) {
      console.warn("SetsList: required DOM elements missing");
    } else {

    let selectedYear = Number(initialYear);
    let offset = 0;
    let loading = false;
    let done = false;
    let items = [];

    const dateFmt = new Intl.DateTimeFormat("en-US", {
      month: "short",
      day: "numeric",
      year: "numeric",
    });

    function setYear(newYear) {
      // newYear: number | "all"
      const btns = root.querySelectorAll('button[data-year]');
      btns.forEach((btn) => {
        const y = btn.getAttribute("data-year");
        const isSelected =
          (newYear === "all" && y === "all") ||
          (typeof newYear === "number" && y === String(newYear));
        btn.setAttribute("aria-pressed", String(isSelected));
        btn.dataset.selected = String(isSelected);
      });
    }

    function trackCountLabel(set) {
      const tc = set.track_count;
      return tc == null ? "—" : String(tc);
    }

    function renderSets(nextItems) {
      listEl.innerHTML = "";
      for (const s of nextItems) {
        const a = document.createElement("a");
        a.href = `/sets/${s.id}`;
        a.className =
          "group grid grid-cols-[1fr_auto] items-center gap-4 rounded-xl border border-white/10 bg-white/[0.02] px-4 py-3 transition-colors hover:border-white/20 hover:bg-white/[0.03]";

        const left = document.createElement("div");
        left.className = "min-w-0";

        const row = document.createElement("div");
        row.className = "flex items-baseline gap-3";

        const date = document.createElement("div");
        date.className = "font-mono text-sm text-slate-200";
        date.textContent = dateFmt.format(new Date(s.set_date));

        const venue = document.createElement("div");
        venue.className = "truncate text-sm font-medium text-slate-100";
        venue.textContent = s.venue;

        row.appendChild(date);
        row.appendChild(venue);
        left.appendChild(row);

        const right = document.createElement("div");
        right.className = "font-mono text-sm text-accent";

        const tc = document.createElement("span");
        tc.textContent = trackCountLabel(s);
        right.appendChild(tc);

        const tracks = document.createElement("span");
        tracks.className = "ml-1 text-slate-400";
        tracks.textContent = "tracks";
        right.appendChild(tracks);

        a.appendChild(left);
        a.appendChild(right);
        listEl.appendChild(a);
      }
    }

    async function load(reset = false) {
      if (loading || done) return;
      loading = true;
      loadMoreBtn.disabled = true;

      if (reset) {
        offset = 0;
        items = [];
        listEl.innerHTML = "";
      }

      const params = {
        limit: pageSize,
        offset,
      };

      // Treat "all" as year-less query.
      if (!Number.isNaN(selectedYear)) params.year = selectedYear;

      statusText.textContent = "Loading…";
      try {
        const res = await getSets(params);
        if (!Array.isArray(res) || res.length === 0) {
          done = reset ? false : done;
          items = reset ? [] : items;
          renderSets(items);
          statusText.textContent = reset
            ? "No sets found for that filter."
            : "";
          return;
        }

        items = reset ? res : [...items, ...res];
        renderSets(items);
        offset += res.length;

        if (res.length < pageSize) {
          done = true;
          statusText.textContent = "End of results.";
        } else {
          statusText.textContent = "";
          loadMoreBtn.disabled = false;
        }
      } catch {
        statusText.textContent = "Failed to load sets. Check CORS/`PUBLIC_API_URL`.";
      } finally {
        loading = false;
        loadMoreBtn.disabled = done;
      }
    }

    // Initial fetch (default year: 2026).
    load(true);

    root.addEventListener("click", (e) => {
      const target = e.target;
      if (!(target instanceof HTMLElement)) return;
      const btn = target.closest("button[data-year]");
      if (!btn) return;

      const raw = btn.getAttribute("data-year");
      if (!raw) return;

      const newYear = raw === "all" ? "all" : Number(raw);
      if (newYear !== "all") selectedYear = newYear;
      else selectedYear = NaN;

      setYear(newYear);
      done = false;
      load(true);
    });

    loadMoreBtn.addEventListener("click", () => load(false));
    }
  </script>
</section>

