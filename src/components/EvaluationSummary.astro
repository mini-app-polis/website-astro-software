---
---

<section
  class="rounded-2xl border border-white/10 bg-white/[0.02] p-6 shadow-soft"
  data-eval-summary
>
  <div class="flex items-start justify-between gap-4">
    <div>
      <h3 class="font-display text-xl tracking-tight">Pipeline Evaluation</h3>
      <p class="mt-1 text-sm text-slate-400">
        AI-assisted conformance checks after every pipeline run
      </p>
    </div>
    <div
      class="flex shrink-0 rounded-full border border-white/10 bg-black/20 p-0.5 text-xs font-mono"
      data-eval-toggle
    >
      <button type="button" data-view="repo" class="rounded-full px-3 py-1 transition-colors">
        By Repo
      </button>
      <button type="button" data-view="dimension" class="rounded-full px-3 py-1 transition-colors">
        By Dimension
      </button>
      <button type="button" data-view="rule" class="rounded-full px-3 py-1 transition-colors">
        By Rule
      </button>
    </div>
  </div>

  <!-- Run type selector — one card per source bucket -->
  <div class="mt-4 grid grid-cols-1 gap-2 sm:grid-cols-2 lg:grid-cols-4" data-eval-source-tabs>
    {["Deterministic", "LLM Conformance", "Pipeline Eval", "Introspection"].map((label) => (
      <button
        type="button"
        class="rounded-lg border border-white/5 bg-black/10 px-4 py-3 text-left transition-colors hover:border-white/10"
        data-source-tab
        data-source-label={label}
        data-selected="false"
        aria-pressed="false"
      >
        <div class="text-xs font-mono font-medium text-slate-300" data-tab-label>{label}</div>
        <div class="mt-1 text-xs text-slate-500" data-tab-counts>—</div>
        <div class="mt-1 text-xs text-slate-600" data-tab-time>—</div>
      </button>
    ))}
  </div>

  <div class="mt-5 space-y-3" data-eval-summary-list>
    {Array.from({ length: 3 }).map(() => (
      <div class="flex items-center justify-between gap-4 rounded-lg border border-white/5 bg-black/10 px-4 py-3">
        <div class="h-4 w-40 animate-pulse rounded bg-white/10"></div>
        <div class="h-4 w-28 animate-pulse rounded bg-white/10"></div>
      </div>
    ))}
  </div>

  <p class="mt-4 text-xs text-slate-500" data-eval-footer>
    Evaluated by Claude · <span data-eval-standards-version>Standards v—</span>
  </p>

  <script type="module">
    const root = document.querySelector("[data-eval-summary]");
    if (!root) throw new Error("EvaluationSummary root not found");

    const listEl = root.querySelector("[data-eval-summary-list]");
    const toggleEl = root.querySelector("[data-eval-toggle]");
    const sourceTabsEl = root.querySelector("[data-eval-source-tabs]");
    if (!listEl || !toggleEl || !sourceTabsEl) throw new Error("EvaluationSummary elements not found");

    const BASE = document.documentElement.dataset.apiUrl || "";
    if (!BASE) {
      root.classList.add("hidden");
    } else {
      const baseUrl = String(BASE).replace(/\/$/, "");
      const rtf = new Intl.RelativeTimeFormat("en", { numeric: "auto" });

      let currentView = "repo";
      // selectedSource is one of "deterministic", "llm", "pipeline", "introspection"
      let selectedSource = "deterministic";
      // findingsByBucket: keyed by bucket name, value is array of findings
      let findingsByBucket = {
        deterministic: [],
        llm: [],
        pipeline: [],
        introspection: [],
      };

      // Source value -> bucket name
      // Seven canonical source values (see ecosystem-standards/standards/evaluation.yaml):
      //   conformance_deterministic      -> deterministic
      //   conformance_llm                -> llm
      //   flow_inline, flow_hook,        -> pipeline
      //   prefect_webhook
      //   standards_drift, data_quality  -> introspection  (evaluator's own
      //     output / inventory — not about any target repo)
      //
      // Legacy aliases during source-rename transition (pre-rename rows still
      // live in the DB with these names):
      //   conformance_check -> llm  (the old name for conformance_llm)
      function sourceToBucket(source) {
        const s = String(source || "");
        if (s === "conformance_deterministic") return "deterministic";
        if (s === "conformance_llm" || s === "conformance_check") return "llm";
        if (
          s === "flow_inline" ||
          s === "flow_hook" ||
          s === "prefect_webhook"
        ) return "pipeline";
        if (s === "standards_drift" || s === "data_quality") return "introspection";
        // Unknown/legacy source — fall back to pipeline bucket so it's still
        // visible rather than silently dropped.
        return "pipeline";
      }

      // Bucket name -> display label
      const BUCKET_LABELS = {
        deterministic: "Deterministic",
        llm: "LLM Conformance",
        pipeline: "Pipeline Eval",
        introspection: "Introspection",
      };

      // -- Helpers -----------------------------------------------
      function normalizeSeverity(level) {
        const s = String(level ?? "INFO").toUpperCase();
        if (s === "WARNING") return "WARN";
        if (s === "CRITICAL" || s === "SUCCESS") return s;
        return s;
      }

      function relativeTime(iso) {
        if (!iso) return "—";
        const d = new Date(iso);
        if (Number.isNaN(d.getTime())) return "—";
        const sec = Math.round((d.getTime() - Date.now()) / 1000);
        const abs = Math.abs(sec);
        if (abs < 60) return rtf.format(sec, "second");
        const min = Math.round(sec / 60);
        if (Math.abs(min) < 60) return rtf.format(min, "minute");
        const hr = Math.round(min / 60);
        if (Math.abs(hr) < 24) return rtf.format(hr, "hour");
        return rtf.format(Math.round(hr / 24), "day");
      }

      function countSeverities(findings) {
        let critical = 0, error = 0, warn = 0, info = 0, success = 0;
        for (const f of findings) {
          const sev = normalizeSeverity(f?.severity);
          if (sev === "CRITICAL") critical++;
          else if (sev === "ERROR") error++;
          else if (sev === "WARN") warn++;
          else if (sev === "SUCCESS") success++;
          else info++;
        }
        return { critical, error, warn, info, success };
      }

      function formatCounts({ critical, error, warn, info, success }) {
        const parts = [];
        if (critical > 0) parts.push(`<span class="text-rose-300">${critical} critical</span>`);
        if (error > 0) parts.push(`<span class="text-red-400">${error} error</span>`);
        if (warn > 0) parts.push(`<span class="text-amber-400">${warn} warn</span>`);
        if (info > 0) parts.push(`<span class="text-slate-400">${info} info</span>`);
        if (success > 0) parts.push(`<span class="text-emerald-400">${success} success</span>`);
        return parts.join('<span class="text-slate-600"> · </span>') || '<span class="text-slate-500">No findings</span>';
      }

      function latestTs(findings) {
        let max = 0;
        for (const f of findings) {
          const t = new Date(f?.evaluated_at || f?.created_at || 0).getTime();
          if (!Number.isNaN(t) && t > max) max = t;
        }
        return max;
      }

      function formatDimension(raw) {
        return String(raw || "")
          .split("_")
          .filter(Boolean)
          .map((w) => w[0].toUpperCase() + w.slice(1))
          .join(" ");
      }

      // -- Toggle (By Repo / By Dimension) -----------------------
      function updateToggle() {
        toggleEl.querySelectorAll("button[data-view]").forEach((btn) => {
          const active = btn.getAttribute("data-view") === currentView;
          btn.className = active
            ? "rounded-full bg-white/10 px-3 py-1 text-slate-100 transition-colors"
            : "rounded-full px-3 py-1 text-slate-500 transition-colors hover:text-slate-300";
        });
      }
      updateToggle();

      toggleEl.addEventListener("click", (e) => {
        const btn = e.target.closest("button[data-view]");
        if (!btn) return;
        const v = btn.getAttribute("data-view");
        if (v === currentView) return;
        currentView = v;
        updateToggle();
        renderList();
      });

      // -- Source tabs -------------------------------------------
      function updateSourceTabs() {
        sourceTabsEl.querySelectorAll("[data-source-tab]").forEach((tab) => {
          const label = tab.getAttribute("data-source-label");
          const bucket = Object.keys(BUCKET_LABELS).find(
            (k) => BUCKET_LABELS[k] === label
          );
          const active = bucket === selectedSource;
          tab.setAttribute("data-selected", active ? "true" : "false");
          tab.setAttribute("aria-pressed", active ? "true" : "false");
          tab.className = active
            ? "rounded-lg border border-accent/40 bg-accent/10 px-4 py-3 text-left transition-colors"
            : "rounded-lg border border-white/5 bg-black/10 px-4 py-3 text-left transition-colors hover:border-white/10";
        });
      }

      function populateSourceTabs() {
        sourceTabsEl.querySelectorAll("[data-source-tab]").forEach((tab) => {
          const label = tab.getAttribute("data-source-label");
          const bucket = Object.keys(BUCKET_LABELS).find(
            (k) => BUCKET_LABELS[k] === label
          );
          if (!bucket) return;
          const findings = findingsByBucket[bucket] || [];
          const counts = countSeverities(findings);
          const ts = latestTs(findings);

          const countsEl = tab.querySelector("[data-tab-counts]");
          const timeEl = tab.querySelector("[data-tab-time]");
          if (countsEl) countsEl.innerHTML = formatCounts(counts);
          if (timeEl) timeEl.textContent = ts > 0 ? relativeTime(new Date(ts).toISOString()) : "—";
        });
        updateSourceTabs();
      }

      sourceTabsEl.addEventListener("click", (e) => {
        const tab = e.target.closest("[data-source-tab]");
        if (!tab) return;
        const label = tab.getAttribute("data-source-label");
        const bucket = Object.keys(BUCKET_LABELS).find(
          (k) => BUCKET_LABELS[k] === label
        );
        if (!bucket || bucket === selectedSource) return;
        selectedSource = bucket;
        updateSourceTabs();
        renderList();
      });

      // -- List (By Repo / By Dimension / By Rule) ---------------
      function aggregateByRepo(findings) {
        const map = new Map();
        for (const f of findings) {
          const key = String(f?.repo || f?.repository || "unknown").trim();
          const sev = normalizeSeverity(f?.severity);
          const ts = new Date(f?.evaluated_at || f?.created_at || 0).getTime();
          if (!map.has(key)) map.set(key, { critical: 0, error: 0, warn: 0, info: 0, success: 0, latestMs: 0 });
          const e = map.get(key);
          if (sev === "CRITICAL") e.critical++;
          else if (sev === "ERROR") e.error++;
          else if (sev === "WARN") e.warn++;
          else if (sev === "SUCCESS") e.success++;
          else e.info++;
          if (!Number.isNaN(ts) && ts > e.latestMs) e.latestMs = ts;
        }
        return [...map.entries()]
          .sort(([, a], [, b]) => (b.critical + b.error) - (a.critical + a.error) || b.warn - a.warn)
          .map(([key, counts]) => ({ label: key, mono: true, ...counts }));
      }

      function aggregateByDimension(findings) {
        const map = new Map();
        for (const f of findings) {
          const key = String(f?.dimension || "unknown").trim();
          const sev = normalizeSeverity(f?.severity);
          const ts = new Date(f?.evaluated_at || f?.created_at || 0).getTime();
          if (!map.has(key)) map.set(key, { critical: 0, error: 0, warn: 0, info: 0, success: 0, latestMs: 0 });
          const e = map.get(key);
          if (sev === "CRITICAL") e.critical++;
          else if (sev === "ERROR") e.error++;
          else if (sev === "WARN") e.warn++;
          else if (sev === "SUCCESS") e.success++;
          else e.info++;
          if (!Number.isNaN(ts) && ts > e.latestMs) e.latestMs = ts;
        }
        return [...map.entries()]
          .sort(([, a], [, b]) => (b.critical + b.error) - (a.critical + a.error) || b.warn - a.warn)
          .map(([key, counts]) => ({ label: formatDimension(key), mono: false, ...counts }));
      }

      // Group findings by rule identifier. The API's `violation_id` field
      // carries the rule code (e.g. "CD-012", "EVAL-007"). Fall back to
      // `rule_id`, then dimension, then "unknown" so every finding lands
      // under some key.
      function aggregateByRule(findings) {
        const map = new Map();
        for (const f of findings) {
          const rawKey =
            f?.violation_id || f?.rule_id || f?.dimension || "unknown";
          const key = String(rawKey).trim() || "unknown";
          const sev = normalizeSeverity(f?.severity);
          const ts = new Date(f?.evaluated_at || f?.created_at || 0).getTime();
          if (!map.has(key)) map.set(key, { critical: 0, error: 0, warn: 0, info: 0, success: 0, latestMs: 0 });
          const e = map.get(key);
          if (sev === "CRITICAL") e.critical++;
          else if (sev === "ERROR") e.error++;
          else if (sev === "WARN") e.warn++;
          else if (sev === "SUCCESS") e.success++;
          else e.info++;
          if (!Number.isNaN(ts) && ts > e.latestMs) e.latestMs = ts;
        }
        return [...map.entries()]
          .sort(([, a], [, b]) => (b.critical + b.error) - (a.critical + a.error) || b.warn - a.warn)
          .map(([key, counts]) => ({ label: key, mono: true, ...counts }));
      }

      function renderList() {
        const findings = findingsByBucket[selectedSource] || [];
        const rows =
          currentView === "repo"
            ? aggregateByRepo(findings)
            : currentView === "rule"
              ? aggregateByRule(findings)
              : aggregateByDimension(findings);

        listEl.innerHTML = "";

        if (findings.length === 0) {
          const empty = document.createElement("p");
          empty.className = "text-sm text-slate-500";
          empty.textContent = "No findings for this run type.";
          listEl.appendChild(empty);
          return;
        }

        rows.forEach((item, idx) => {
          const row = document.createElement("div");
          row.className =
            "reveal flex items-center justify-between gap-4 rounded-lg border border-white/5 bg-black/10 px-4 py-3";
          row.style.setProperty("--d", `${idx * 80}ms`);

          const critTag = item.critical > 0 ? `<span class="text-rose-300">${item.critical} critical</span>` : "";
          const errTag = item.error > 0 ? `<span class="text-red-400">${item.error} error</span>` : "";
          const warnTag = item.warn > 0 ? `<span class="text-amber-400">${item.warn} warn</span>` : "";
          const infoTag = item.info > 0 ? `<span class="text-slate-400">${item.info} info</span>` : "";
          const successTag = item.success > 0 ? `<span class="text-emerald-400">${item.success} success</span>` : "";
          const tags = [critTag, errTag, warnTag, infoTag, successTag].filter(Boolean).join(" · ");

          row.innerHTML = `
            <div class="min-w-0">
              <div class="${item.mono ? "font-mono" : ""} text-sm font-medium text-slate-100">
                ${item.label}
              </div>
              <div class="mt-1 text-sm">
                ${tags || '<span class="text-slate-500">No findings</span>'}
              </div>
            </div>
            <div class="shrink-0 text-xs text-slate-400">
              ${relativeTime(new Date(item.latestMs).toISOString())}
            </div>
          `;
          listEl.appendChild(row);
        });
      }

      // -- Load --------------------------------------------------
      // Page through /v1/evaluations until we've collected every eligible
      // row the API would return (or we hit the safety cap). The API
      // already filters server-side to "latest run per (repo, source)" via
      // its eligibility subquery, so the envelope's `total` is the bounded
      // count of rows we need to pull. Using the envelope `total` lets us
      // stop cleanly rather than hoping a single large limit is enough.
      async function fetchAllEvaluations() {
        const PAGE_SIZE = 500; // API cap
        const SAFETY_CAP = 5000;
        const collected = [];
        let offset = 0;

        // First page — reads total from envelope.
        const firstRes = await fetch(
          `${baseUrl}/v1/evaluations?limit=${PAGE_SIZE}&offset=0`,
          { cache: "no-store" }
        );
        if (!firstRes.ok) return null;
        const firstJson = await firstRes.json();
        const firstData = firstJson?.data ?? [];
        if (!Array.isArray(firstData)) return null;
        collected.push(...firstData);
        const total = Number(firstJson?.total ?? firstData.length);
        offset = collected.length;

        // Remaining pages — bounded by total and safety cap. The inner
        // break on data.length === 0 handles the case where the API
        // stops returning rows earlier than `total` suggests.
        while (offset < total && collected.length < SAFETY_CAP) {
          const res = await fetch(
            `${baseUrl}/v1/evaluations?limit=${PAGE_SIZE}&offset=${offset}`,
            { cache: "no-store" }
          );
          if (!res.ok) break;
          const json = await res.json();
          const data = json?.data ?? [];
          if (!Array.isArray(data) || data.length === 0) break;
          collected.push(...data);
          offset += data.length;
        }

        return collected;
      }

      async function load() {
        try {
          const allFindings = await fetchAllEvaluations();
          if (!Array.isArray(allFindings) || allFindings.length === 0) {
            root.classList.add("hidden");
            return;
          }

          // Find the latest run_id per source type
          const latestBySource = new Map();
          for (const f of allFindings) {
            const source = String(f?.source || "unknown");
            const ts = new Date(f?.evaluated_at || f?.created_at || 0).getTime();
            if (!Number.isNaN(ts)) {
              const existing = latestBySource.get(source);
              if (!existing || ts > existing.ts) {
                latestBySource.set(source, { ts, runId: f?.run_id ?? null });
              }
            }
          }

          // Scope to latest run per source
          const latestRunIds = new Set(
            [...latestBySource.values()].map((v) => v.runId).filter(Boolean)
          );
          const findings = latestRunIds.size > 0
            ? allFindings.filter((f) => latestRunIds.has(f?.run_id ?? null))
            : allFindings;

          // Split into buckets
          findingsByBucket = {
            deterministic: [],
            llm: [],
            pipeline: [],
            introspection: [],
          };
          for (const f of findings) {
            const bucket = sourceToBucket(f?.source);
            findingsByBucket[bucket].push(f);
          }

          // Standards version footer
          const footerVersionEl = root.querySelector("[data-eval-standards-version]");
          if (footerVersionEl) {
            const sv = findings.find((f) => f?.standards_version)?.standards_version;
            if (sv) footerVersionEl.textContent = `Standards v${sv}`;
          }

          populateSourceTabs();
          renderList();
        } catch {
          root.classList.add("hidden");
        }
      }

      void load();
    }
  </script>
</section>
