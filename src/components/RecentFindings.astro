---
---

<section
  class="rounded-2xl border border-white/10 bg-white/[0.02] p-6 shadow-soft"
  data-recent-findings
>
  <div class="space-y-2" data-recent-findings-list>
    {Array.from({ length: 5 }).map(() => (
      <div class="rounded-lg border border-white/5 bg-black/10 px-4 py-3">
        <div class="h-4 w-24 animate-pulse rounded bg-white/10"></div>
        <div class="mt-2 h-4 w-48 animate-pulse rounded bg-white/10"></div>
        <div class="mt-2 h-8 w-full animate-pulse rounded bg-white/10"></div>
      </div>
    ))}
  </div>

  <script>
    import { normalizeSeverity, severityClass } from "../lib/severity";
    import { sourceLabel } from "../lib/sources";

    const root = document.querySelector("[data-recent-findings]");
    if (!root) throw new Error("RecentFindings root not found");
    const listEl = root.querySelector("[data-recent-findings-list]");
    if (!listEl) throw new Error("RecentFindings list not found");

    const BASE = document.documentElement.dataset.apiUrl || "";
    if (!BASE) {
      root.classList.add("hidden");
    } else {
      const baseUrl = String(BASE).replace(/\/$/, "");
      const url = `${baseUrl}/v1/evaluations?limit=5`;
      const rtf = new Intl.RelativeTimeFormat("en", { numeric: "auto" });

      function formatDimension(raw) {
        return String(raw ?? "")
          .split("_")
          .filter(Boolean)
          .map((w) => w[0].toUpperCase() + w.slice(1))
          .join(" ");
      }

      function relativeTime(iso) {
        if (!iso) return "—";
        const d = new Date(iso);
        if (Number.isNaN(d.getTime())) return "—";
        const sec = Math.round((d.getTime() - Date.now()) / 1000);
        const abs = Math.abs(sec);
        if (abs < 60) return rtf.format(sec, "second");
        const min = Math.round(sec / 60);
        if (Math.abs(min) < 60) return rtf.format(min, "minute");
        const hr = Math.round(min / 60);
        if (Math.abs(hr) < 24) return rtf.format(hr, "hour");
        const day = Math.round(hr / 24);
        return rtf.format(day, "day");
      }

      function collapseConsecutiveInfo(rows) {
        const collapsed = [];
        for (const row of rows) {
          const sev = normalizeSeverity(row?.severity);
          const msg = String(row?.finding ?? row?.message ?? row?.text ?? "");
          const dim = String(row?.dimension ?? "");

          if (sev !== "INFO") {
            collapsed.push({ ...row, _repeatRuns: 1, _severity: sev });
            continue;
          }

          const prev = collapsed[collapsed.length - 1];
          if (
            prev &&
            prev._severity === "INFO" &&
            String(prev?.dimension ?? "") === dim &&
            String(prev?._message ?? prev?.finding ?? prev?.message ?? prev?.text ?? "") === msg
          ) {
            prev._repeatRuns = Number(prev._repeatRuns || 1) + 1;
            continue;
          }

          collapsed.push({
            ...row,
            _repeatRuns: 1,
            _severity: "INFO",
            _message: msg,
          });
        }
        return collapsed;
      }

      async function load() {
        try {
          const res = await fetch(url, { cache: "no-store" });
          if (!res.ok) {
            root.classList.add("hidden");
            return;
          }
          const json = await res.json();
          const data = json?.data ?? [];
          if (!Array.isArray(data) || data.length === 0) {
            root.classList.add("hidden");
            return;
          }

          const raw = data.slice(0, 50);
          const collapsed = collapseConsecutiveInfo(raw);
          const pinned = [
            ...collapsed.filter((f) => {
              const sev = normalizeSeverity(f?._severity ?? f?.severity);
              return sev === "CRITICAL" || sev === "ERROR" || sev === "WARN";
            }),
            ...collapsed.filter((f) => normalizeSeverity(f?._severity ?? f?.severity) === "INFO"),
          ].slice(0, 5);

          listEl.innerHTML = "";

          let markedError = false;
          let markedWarn = false;

          pinned.forEach((f, idx) => {
            const severity = normalizeSeverity(f?._severity ?? f?.severity);
            const timestamp = f?.created_at ?? f?.most_recent ?? f?.timestamp ?? null;
            const findingText = f?.finding ?? f?.message ?? f?.text ?? "";
            const row = document.createElement("article");
            row.className = "reveal rounded-lg border border-white/5 bg-black/10 px-4 py-3";
            row.style.setProperty("--d", `${idx * 100}ms`);

            if (severity === "ERROR" && !markedError) {
              row.id = "finding-error-first";
              markedError = true;
            }
            if (severity === "WARN" && !markedWarn) {
              row.id = "finding-warn-first";
              markedWarn = true;
            }

            const repeatRuns = Number(f?._repeatRuns || 1);
            const repeatBadge =
              severity === "INFO" && repeatRuns > 1
                ? `<span class="inline-flex items-center rounded-full border border-slate-500/30 bg-slate-500/10 px-2 py-0.5 text-[11px] font-mono text-slate-300">× ${repeatRuns} runs</span>`
                : "";
            const src = sourceLabel(f?.source);
            const sourceBadge = src
              ? `<span class="inline-flex items-center rounded-full border border-slate-600/40 bg-slate-700/30 px-2 py-0.5 text-[11px] font-mono text-slate-400">${src}</span>`
              : "";
            const flowBadge = f?.flow_name
              ? `<span class="inline-flex items-center rounded-full border border-slate-600/40 bg-slate-700/30 px-2 py-0.5 text-[11px] font-mono text-slate-400">${f.flow_name}</span>`
              : "";
            const repoBadge = f?.repo
              ? `<span class="inline-flex items-center rounded-full border border-violet-500/30 bg-violet-500/10 px-2 py-0.5 text-[11px] font-mono text-violet-300">${f.repo}</span>`
              : "";

            row.innerHTML = `
              <div class="flex items-center justify-between gap-3">
                <div class="flex items-center gap-2">
                  <div class="inline-flex items-center rounded-full border px-2 py-0.5 text-xs font-mono ${severityClass(
                    severity,
                  )}">${severity}</div>
                  ${repoBadge}
                  ${flowBadge}
                  ${sourceBadge}
                  ${repeatBadge}
                </div>
                <div class="text-xs text-slate-400">${relativeTime(timestamp)}</div>
              </div>
              <div class="mt-2 text-sm font-medium text-slate-200">${formatDimension(
                f?.dimension,
              ) || "Unknown Dimension"}</div>
              <p class="mt-1 text-sm text-slate-400 overflow-hidden [display:-webkit-box] [-webkit-box-orient:vertical] [-webkit-line-clamp:2]">${String(
                findingText,
              )}</p>
            `;
            listEl.appendChild(row);
          });
        } catch {
          root.classList.add("hidden");
        }
      }

      void load();
    }
  </script>
</section>

