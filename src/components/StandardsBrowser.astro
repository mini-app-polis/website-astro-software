---
/**
 * StandardsBrowser
 *
 * Fetches the ecosystem-standards rules at build time and renders a
 * browsable view grouped by domain. Each rule shows its ID, title,
 * severity, status, and description. All fetches are build-time (SSG) —
 * no client-side API calls.
 *
 * Source of truth: index.yaml (domain discovery + labels via description)
 * and standards/*.yaml (rules). See src/lib/standards.ts.
 */

import { fetchIndex, fetchDomainFiles, type Rule } from "../lib/standards";

const [index, domainResults] = await Promise.all([
  fetchIndex(),
  fetchDomainFiles(),
]);

const fetchError = index == null || domainResults.length === 0;

// Build the per-domain display list. We use the description from index.yaml
// as the friendly label where possible; if absent, fall back to the raw key.
// This keeps new domain files correctly labeled without code changes here —
// rename a description in index.yaml and the site picks it up on next build.
function labelFor(key: string, description?: string): string {
  // index.yaml descriptions are sentences (e.g. "Standards for all Python
  // services..."); we want a short label. Prefer a "title case of key"
  // derived from the filename, which matches the domain key convention.
  const base = key
    .split(/[-_]/)
    .filter(Boolean)
    .map((w) => w[0].toUpperCase() + w.slice(1))
    .join(" ");
  return base || description || key;
}

const domainFiles = domainResults
  .map((d) => ({
    key: d.key,
    label: labelFor(d.key, d.description),
    rules: d.rules,
  }))
  .sort((a, b) => a.label.localeCompare(b.label));

const totalRules = domainFiles.reduce((sum, d) => sum + d.rules.length, 0);
const checkableRules = domainFiles.reduce(
  (sum, d) => sum + d.rules.filter((r) => r.checkable === true).length,
  0,
);

// Severity class mapping. Rule-level severities are ERROR | WARN | INFO
// per index.yaml schema.rule_fields.severity.allowed_values. CRITICAL and
// SUCCESS are emission-only and never appear on rule definitions, so we
// don't need them here — but we handle them defensively in case a rule
// somewhere is mislabeled.
function severityClass(severity?: string): string {
  if (severity === "CRITICAL") return "text-rose-300 border-rose-500/40 bg-rose-500/15";
  if (severity === "ERROR") return "text-red-400 border-red-500/30 bg-red-500/10";
  if (severity === "WARN") return "text-amber-400 border-amber-500/30 bg-amber-500/10";
  if (severity === "SUCCESS") return "text-emerald-400 border-emerald-500/30 bg-emerald-500/10";
  return "text-slate-300 border-slate-500/30 bg-slate-500/10";
}

function statusClass(status?: string): string {
  if (status === "requirement") return "text-accent border-accent/30 bg-accent/10";
  if (status === "convention") return "text-sky-400 border-sky-500/30 bg-sky-500/10";
  if (status === "gap") return "text-rose-400 border-rose-500/30 bg-rose-500/10";
  return "text-slate-500 border-white/10 bg-white/5";
}
---

{fetchError ? (
  <p class="text-sm text-slate-500">
    Unable to load standards — check back shortly or view the
    <a
      href="https://github.com/mini-app-polis/ecosystem-standards"
      target="_blank"
      rel="noreferrer"
      class="text-slate-300 underline hover:text-slate-100"
    >repo directly</a>.
  </p>
) : (
  <div class="space-y-3">
    <!-- Header row: counts + link to standards repo -->
    <div class="flex flex-wrap items-center gap-x-6 gap-y-2">
      <span class="text-xs text-slate-500">
        {totalRules} rules · {checkableRules} checkable
      </span>
      <a
        href="https://github.com/mini-app-polis/ecosystem-standards"
        target="_blank"
        rel="noreferrer"
        class="font-mono text-xs text-slate-500 transition-colors hover:text-slate-200"
      >
        GitHub ↗
      </a>
    </div>

    <!-- Domain sections -->
    {domainFiles.map((domain) => (
      <details class="group rounded-xl border border-white/10 bg-white/[0.02]" open={false}>
        <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-4 py-3 hover:bg-white/[0.02]">
          <div class="flex items-center gap-3">
            <span class="font-display text-sm tracking-tight text-slate-100">
              {domain.label}
            </span>
            <span class="font-mono text-xs text-slate-500">
              {domain.rules.length} rules
            </span>
          </div>
          <svg
            class="h-4 w-4 shrink-0 text-slate-500 transition-transform group-open:rotate-180"
            viewBox="0 0 16 16"
            fill="none"
          >
            <path
              d="M4 6l4 4 4-4"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </summary>

        <div class="divide-y divide-white/5 border-t border-white/5">
          {domain.rules.map((rule: Rule) => (
            <div class="space-y-1.5 px-4 py-3">
              <div class="flex flex-wrap items-center gap-2">
                <span class="font-mono text-xs text-slate-500">{rule.id}</span>
                {rule.severity && (
                  <span
                    class={`inline-flex items-center rounded-full border px-2 py-0.5 text-xs font-mono ${severityClass(rule.severity)}`}
                  >
                    {rule.severity}
                  </span>
                )}
                {rule.status && (
                  <span
                    class={`inline-flex items-center rounded-full border px-2 py-0.5 text-xs font-mono capitalize ${statusClass(rule.status)}`}
                  >
                    {rule.status}
                  </span>
                )}
                {rule.checkable && (
                  <span class="inline-flex items-center rounded-full border border-emerald-500/30 bg-emerald-500/10 px-2 py-0.5 text-xs font-mono text-emerald-400">
                    checkable
                  </span>
                )}
              </div>
              <p class="text-sm font-medium text-slate-200">{rule.title}</p>
              <p class="text-xs leading-relaxed text-slate-400">{rule.description}</p>
            </div>
          ))}
        </div>
      </details>
    ))}
  </div>
)}
