---
/**
 * Sub-tabs for /pipeline and /pipeline/summary. Displayed at the top of
 * either page so users can move between the filtered details view and
 * the ecosystem-wide summary view without going back to the top nav.
 *
 * The main Nav component highlights the "Pipeline" top-level link on
 * both paths; this component disambiguates which sub-view is active.
 */
const { pathname } = Astro.url;

type Tab = { href: string; label: string };
const tabs: Tab[] = [
  { href: "/pipeline", label: "Details" },
  { href: "/pipeline/summary", label: "Summary" },
];

function isActive(href: string) {
  // Exact match — /pipeline must not claim active when on /pipeline/summary.
  if (pathname.endsWith("/") && pathname !== "/") {
    return pathname.slice(0, -1) === href;
  }
  return pathname === href;
}
---

<div class="flex items-center gap-2 text-xs font-mono" aria-label="Pipeline sections">
  {tabs.map((tab) => {
    const active = isActive(tab.href);
    return (
      <a
        href={tab.href}
        data-selected={active ? "true" : "false"}
        aria-current={active ? "page" : undefined}
        class="rounded-full border border-white/10 bg-white/[0.02] px-3 py-1 transition-colors hover:border-white/20 hover:text-slate-100 data-[selected=true]:border-accent data-[selected=true]:bg-accent/15 data-[selected=true]:text-accent"
      >
        {tab.label}
      </a>
    );
  })}
</div>
