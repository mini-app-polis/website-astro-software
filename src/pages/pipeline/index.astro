---
import Page from "../../layouts/Page.astro";
import EvaluationSummary from "../../components/EvaluationSummary.astro";

const subtitle =
  "AI evaluation findings from every pipeline run, evaluated by Claude against the engineering standards document.";
---

<Page title="Pipeline Health" subtitle={subtitle}>
  <div class="space-y-12">
    <section class="space-y-3">
      <h2 class="font-display text-xl tracking-tight">Summary</h2>
      <EvaluationSummary />
    </section>

    <section class="space-y-5" data-pipeline-browser>
      <div>
        <h2 class="font-display text-xl tracking-tight">Findings</h2>
        <p class="mt-1 text-sm text-slate-400">
          Browse individual findings from recent pipeline runs. Filter by severity and repository.
        </p>
      </div>

      <div class="flex flex-wrap items-center gap-x-8 gap-y-3">
        <div class="flex flex-wrap items-center gap-2">
          <span class="text-xs font-mono text-slate-500">Severity</span>
          <div class="flex flex-wrap items-center gap-2" data-severity-buttons>
            <button
              type="button"
              data-severity=""
              data-selected="true"
              aria-pressed="true"
              class="rounded-full border border-white/10 bg-white/[0.02] px-3 py-1 text-xs font-mono transition-colors hover:border-white/20 hover:text-slate-100 data-[selected=true]:border-accent data-[selected=true]:bg-accent/15 data-[selected=true]:text-accent"
            >
              All
            </button>
            <button
              type="button"
              data-severity="ERROR"
              data-selected="false"
              aria-pressed="false"
              class="rounded-full border border-white/10 bg-white/[0.02] px-3 py-1 text-xs font-mono transition-colors hover:border-white/20 hover:text-slate-100 data-[selected=true]:border-accent data-[selected=true]:bg-accent/15 data-[selected=true]:text-accent"
            >
              ERROR
            </button>
            <button
              type="button"
              data-severity="WARN"
              data-selected="false"
              aria-pressed="false"
              class="rounded-full border border-white/10 bg-white/[0.02] px-3 py-1 text-xs font-mono transition-colors hover:border-white/20 hover:text-slate-100 data-[selected=true]:border-accent data-[selected=true]:bg-accent/15 data-[selected=true]:text-accent"
            >
              WARN
            </button>
            <button
              type="button"
              data-severity="INFO"
              data-selected="false"
              aria-pressed="false"
              class="rounded-full border border-white/10 bg-white/[0.02] px-3 py-1 text-xs font-mono transition-colors hover:border-white/20 hover:text-slate-100 data-[selected=true]:border-accent data-[selected=true]:bg-accent/15 data-[selected=true]:text-accent"
            >
              INFO
            </button>
            <button
              type="button"
              data-severity="CRITICAL"
              data-selected="false"
              aria-pressed="false"
              class="rounded-full border border-white/10 bg-white/[0.02] px-3 py-1 text-xs font-mono transition-colors hover:border-white/20 hover:text-slate-100 data-[selected=true]:border-rose-400 data-[selected=true]:bg-rose-500/15 data-[selected=true]:text-rose-300"
            >
              CRITICAL
            </button>
            <button
              type="button"
              data-severity="SUCCESS"
              data-selected="false"
              aria-pressed="false"
              class="rounded-full border border-white/10 bg-white/[0.02] px-3 py-1 text-xs font-mono transition-colors hover:border-white/20 hover:text-slate-100 data-[selected=true]:border-emerald-400 data-[selected=true]:bg-emerald-500/15 data-[selected=true]:text-emerald-300"
            >
              SUCCESS
            </button>
          </div>
        </div>
        <div class="flex flex-wrap items-center gap-2">
          <span class="text-xs font-mono text-slate-500">Repo</span>
          <div class="flex flex-wrap items-center gap-2" data-repo-buttons>
            <button
              type="button"
              data-repo=""
              data-selected="true"
              aria-pressed="true"
              class="rounded-full border border-white/10 bg-white/[0.02] px-3 py-1 text-xs font-mono transition-colors hover:border-white/20 hover:text-slate-100 data-[selected=true]:border-accent data-[selected=true]:bg-accent/15 data-[selected=true]:text-accent"
            >
              All
            </button>
          </div>
        </div>
        <div class="flex flex-wrap items-center gap-2">
          <span class="text-xs font-mono text-slate-500">Dimension</span>
          <div class="flex flex-wrap items-center gap-2" data-dimension-buttons>
            <button
              type="button"
              data-dimension=""
              data-selected="true"
              aria-pressed="true"
              class="rounded-full border border-white/10 bg-white/[0.02] px-3 py-1 text-xs font-mono transition-colors hover:border-white/20 hover:text-slate-100 data-[selected=true]:border-accent data-[selected=true]:bg-accent/15 data-[selected=true]:text-accent"
            >
              All
            </button>
          </div>
        </div>
        <div class="flex flex-wrap items-center gap-2">
          <span class="text-xs font-mono text-slate-500">Run Type</span>
          <div class="flex flex-wrap items-center gap-2" data-source-buttons>
            <button
              type="button"
              data-source=""
              data-selected="true"
              aria-pressed="true"
              class="rounded-full border border-white/10 bg-white/[0.02] px-3 py-1 text-xs font-mono transition-colors hover:border-white/20 hover:text-slate-100 data-[selected=true]:border-accent data-[selected=true]:bg-accent/15 data-[selected=true]:text-accent"
            >
              All
            </button>
            <button
              type="button"
              data-source="conformance_deterministic"
              data-selected="false"
              aria-pressed="false"
              class="rounded-full border border-white/10 bg-white/[0.02] px-3 py-1 text-xs font-mono transition-colors hover:border-white/20 hover:text-slate-100 data-[selected=true]:border-accent data-[selected=true]:bg-accent/15 data-[selected=true]:text-accent"
            >
              Deterministic
            </button>
            <button
              type="button"
              data-source="conformance_llm,conformance_check"
              data-selected="false"
              aria-pressed="false"
              class="rounded-full border border-white/10 bg-white/[0.02] px-3 py-1 text-xs font-mono transition-colors hover:border-white/20 hover:text-slate-100 data-[selected=true]:border-accent data-[selected=true]:bg-accent/15 data-[selected=true]:text-accent"
            >
              LLM Conformance
            </button>
            <button
              type="button"
              data-source="flow_inline,flow_hook,prefect_webhook"
              data-selected="false"
              aria-pressed="false"
              class="rounded-full border border-white/10 bg-white/[0.02] px-3 py-1 text-xs font-mono transition-colors hover:border-white/20 hover:text-slate-100 data-[selected=true]:border-accent data-[selected=true]:bg-accent/15 data-[selected=true]:text-accent"
            >
              Pipeline Eval
            </button>
            <button
              type="button"
              data-source="standards_drift,data_quality"
              data-selected="false"
              aria-pressed="false"
              class="rounded-full border border-white/10 bg-white/[0.02] px-3 py-1 text-xs font-mono transition-colors hover:border-white/20 hover:text-slate-100 data-[selected=true]:border-accent data-[selected=true]:bg-accent/15 data-[selected=true]:text-accent"
            >
              Introspection
            </button>
          </div>
        </div>
      </div>

      <p
        id="pipelineFindingsEmpty"
        class="hidden rounded-2xl border border-white/10 bg-white/[0.02] p-8 text-center text-sm text-slate-400"
      ></p>
      <div id="pipelineFindingsList" class="space-y-8"></div>

      <div class="flex justify-center pt-2">
        <button
          type="button"
          id="pipelineLoadMore"
          class="hidden rounded-full border border-white/10 bg-white/[0.02] px-5 py-2 text-sm font-medium text-slate-200 transition-colors hover:border-white/20 hover:text-slate-100 disabled:opacity-50"
        >
          Load more
        </button>
      </div>
    </section>
  </div>

  <script is:inline>
    (function () {
      var root = document.querySelector("[data-pipeline-browser]");
      if (!root) return;

      var listEl = document.getElementById("pipelineFindingsList");
      var emptyEl = document.getElementById("pipelineFindingsEmpty");
      var loadMoreBtn = document.getElementById("pipelineLoadMore");
      if (!listEl || !emptyEl || !loadMoreBtn) return;

      var BASE = document.documentElement.dataset.apiUrl || "";
      var baseUrl = String(BASE).replace(/\/$/, "");

      var allFindings = [];
      var nextOffset = 0;
      var pageSize = 200;
      var hasMore = false;
      var loading = false;
      var selectedSeverity = "";
      var selectedRepo = "";
      var selectedDimension = "";
      var selectedSource = "";

      var dateFmt = new Intl.DateTimeFormat("en-US", {
        month: "short",
        day: "numeric",
        year: "numeric",
      });
      var timeFmt = new Intl.DateTimeFormat("en-US", {
        hour: "numeric",
        minute: "2-digit",
        hour12: true,
      });

      function evaluatedAt(f) {
        return f.evaluated_at || f.created_at || f.timestamp || f.most_recent || null;
      }

      function formatDimension(raw) {
        return String(raw || "")
          .split("_")
          .filter(Boolean)
          .map(function (w) {
            return w.charAt(0).toUpperCase() + w.slice(1);
          })
          .join(" ");
      }

      function normalizeSeverity(level) {
        var s = String(level || "").toUpperCase();
        if (s === "WARNING") return "WARN";
        if (s === "CRITICAL" || s === "SUCCESS") return s;
        return s || "INFO";
      }

      function severityClass(level) {
        var s = normalizeSeverity(level);
        if (s === "CRITICAL") return "text-rose-300 border-rose-500/40 bg-rose-500/15";
        if (s === "ERROR") return "text-red-400 border-red-500/30 bg-red-500/10";
        if (s === "WARN") return "text-amber-400 border-amber-500/30 bg-amber-500/10";
        if (s === "SUCCESS") return "text-emerald-400 border-emerald-500/30 bg-emerald-500/10";
        return "text-slate-300 border-slate-500/30 bg-slate-500/10";
      }

      function findingRepo(f) {
        return String(f.repo || f.repository || "").trim();
      }

      function findingDimension(f) {
        return String(f.dimension || "").trim();
      }

      function findingText(f) {
        return String(f.finding || f.message || f.text || "");
      }

      function suggestionText(f) {
        return String(f.suggestion || f.suggested_fix || f.remediation || "").trim();
      }

      function filterFindings(items) {
        return items.filter(function (f) {
          if (selectedSeverity) {
            if (normalizeSeverity(f.severity) !== selectedSeverity) return false;
          }
          if (selectedRepo) {
            if (findingRepo(f) !== selectedRepo) return false;
          }
          if (selectedDimension) {
            if (findingDimension(f) !== selectedDimension) return false;
          }
          if (selectedSource) {
            // selectedSource may be a single source string ("flow_inline")
            // or a comma-separated list of source strings for a bucket
            // ("flow_inline,flow_hook,prefect_webhook"). Match if the row's
            // source is in the set.
            var allowed = selectedSource.split(",");
            var rowSource = String(f.source || "").trim();
            var matched = false;
            for (var k = 0; k < allowed.length; k++) {
              if (allowed[k].trim() === rowSource) {
                matched = true;
                break;
              }
            }
            if (!matched) return false;
          }
          return true;
        });
      }

      function groupByRun(findings) {
        var map = new Map();
        for (var i = 0; i < findings.length; i++) {
          var f = findings[i];
          var rid = f.run_id != null ? String(f.run_id) : "unknown";
          if (!map.has(rid)) map.set(rid, []);
          map.get(rid).push(f);
        }
        var runs = [];
        map.forEach(function (items, runId) {
          var maxTs = 0;
          for (var j = 0; j < items.length; j++) {
            var t = new Date(evaluatedAt(items[j]) || 0).getTime();
            if (!Number.isNaN(t) && t > maxTs) maxTs = t;
          }
          runs.push({ runId: runId, items: items, maxTs: maxTs });
        });
        runs.sort(function (a, b) {
          return b.maxTs - a.maxTs;
        });
        return runs;
      }

      function setButtonGroup(container, attrName, value) {
        var btns = container.querySelectorAll("button[" + attrName + "]");
        for (var i = 0; i < btns.length; i++) {
          var btn = btns[i];
          var v = btn.getAttribute(attrName) || "";
          var sel = v === value;
          btn.setAttribute("data-selected", sel ? "true" : "false");
          btn.setAttribute("aria-pressed", sel ? "true" : "false");
        }
      }

      function buildRepoButtons(findings) {
        var repos = [];
        var seen = {};
        for (var i = 0; i < findings.length; i++) {
          var r = findingRepo(findings[i]);
          if (r && !seen[r]) {
            seen[r] = true;
            repos.push(r);
          }
        }
        repos.sort();

        // Remove all buttons except "All"
        var existing = repoWrap.querySelectorAll("button[data-repo]:not([data-repo=''])");
        for (var j = 0; j < existing.length; j++) {
          existing[j].remove();
        }

        // Add a button per repo
        for (var k = 0; k < repos.length; k++) {
          var btn = document.createElement("button");
          btn.type = "button";
          btn.setAttribute("data-repo", repos[k]);
          btn.setAttribute("data-selected", "false");
          btn.setAttribute("aria-pressed", "false");
          btn.className =
            "rounded-full border border-white/10 bg-white/[0.02] px-3 py-1 text-xs font-mono transition-colors hover:border-white/20 hover:text-slate-100 data-[selected=true]:border-accent data-[selected=true]:bg-accent/15 data-[selected=true]:text-accent";
          btn.textContent = repos[k];
          repoWrap.appendChild(btn);
        }
      }

      function buildDimensionButtons(findings) {
        if (!dimWrap) return;
        var dims = [];
        var seen = {};
        for (var i = 0; i < findings.length; i++) {
          var d = findingDimension(findings[i]);
          if (d && !seen[d]) {
            seen[d] = true;
            dims.push(d);
          }
        }
        dims.sort();
        var existing = dimWrap.querySelectorAll("button[data-dimension]:not([data-dimension=''])");
        for (var j = 0; j < existing.length; j++) existing[j].remove();
        for (var k = 0; k < dims.length; k++) {
          var btn = document.createElement("button");
          btn.type = "button";
          btn.setAttribute("data-dimension", dims[k]);
          btn.setAttribute("data-selected", "false");
          btn.setAttribute("aria-pressed", "false");
          btn.className =
            "rounded-full border border-white/10 bg-white/[0.02] px-3 py-1 text-xs font-mono transition-colors hover:border-white/20 hover:text-slate-100 data-[selected=true]:border-accent data-[selected=true]:bg-accent/15 data-[selected=true]:text-accent";
          btn.textContent = dims[k]
            .split("_")
            .filter(Boolean)
            .map(function (w) {
              return w.charAt(0).toUpperCase() + w.slice(1);
            })
            .join(" ");
          dimWrap.appendChild(btn);
        }
      }

      function render() {
        var filtered = filterFindings(allFindings);
        if (allFindings.length === 0) {
          emptyEl.textContent = "No pipeline evaluations recorded yet.";
          emptyEl.classList.remove("hidden");
          listEl.innerHTML = "";
          loadMoreBtn.classList.add("hidden");
          return;
        }
        if (filtered.length === 0) {
          emptyEl.textContent = "No findings match the selected filters.";
          emptyEl.classList.remove("hidden");
          listEl.innerHTML = "";
          loadMoreBtn.classList.toggle("hidden", !hasMore);
          return;
        }
        emptyEl.classList.add("hidden");

        var runs = groupByRun(filtered);
        var html = "";
        for (var r = 0; r < runs.length; r++) {
          var run = runs[r];
          var headerIso = evaluatedAt(run.items[0]);
          var headerD = headerIso ? new Date(headerIso) : null;
          var headerOk = headerD && !Number.isNaN(headerD.getTime());
          var headerDate = headerOk ? dateFmt.format(headerD) : "—";
          var headerTime = headerOk ? timeFmt.format(headerD) : "—";
          html += '<section class="space-y-3"><h3 class="flex flex-wrap items-baseline gap-x-1 text-sm font-normal text-slate-200">';
          html +=
            "<span>" +
            escapeHtml(headerDate) +
            " · " +
            escapeHtml(headerTime) +
            '</span><span class="text-slate-500">  ·  </span><span class="font-mono text-xs text-slate-500">Run ' +
            escapeHtml(run.runId) +
            "</span></h3><div class=\"space-y-3\">";
          for (var j = 0; j < run.items.length; j++) {
            var f = run.items[j];
            var sev = normalizeSeverity(f.severity);
            var sc = severityClass(sev);
            var dim = formatDimension(f.dimension) || "Unknown";
            var flowName = String(f.flow_name || "").trim();
            var ft = findingText(f);
            var sug = suggestionText(f);
            var ridShort =
              String(f.run_id != null ? f.run_id : "")
                .slice(0, 8) || "—";
            html += '<article class="rounded-xl border border-white/10 bg-black/10 p-4">';
            html += '<div class="flex flex-wrap items-start justify-between gap-3">';
            html +=
              '<span class="inline-flex shrink-0 items-center rounded-full border px-2 py-0.5 text-xs font-mono ' +
              sc +
              '">' +
              escapeHtml(sev) +
              "</span>";
            html += '<div class="min-w-0 flex-1 space-y-2">';
            var violationId = String(f.violation_id || "").trim();
            if (violationId) {
              html +=
                '<span class="inline-flex items-center rounded-full border px-2 py-0.5 text-xs font-mono ' +
                sc +
                '">' +
                escapeHtml(violationId) +
                "</span>";
            }
            html +=
              '<div class="text-sm font-medium text-slate-200">' + escapeHtml(dim) + "</div>";
            if (flowName) {
              html +=
                '<div class="text-xs font-mono text-slate-400">' +
                escapeHtml(flowName) +
                "</div>";
            }
            html += '<p class="text-sm leading-relaxed text-slate-300">' + escapeHtml(ft) + "</p>";
            if (sug) {
              html +=
                '<p class="text-xs leading-relaxed text-slate-400">' + escapeHtml(sug) + "</p>";
            }
            html += "</div></div>";
            var repo = findingRepo(f);
            var repoBadge = repo
              ? '<span class="inline-flex items-center rounded-full border border-violet-500/30 bg-violet-500/10 px-2 py-0.5 font-mono text-violet-300">' +
                escapeHtml(repo) +
                "</span>"
              : "";
            html +=
              '<div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-1 border-t border-white/5 pt-3 text-xs text-slate-500">';
            html += repoBadge;
            html +=
              '<span class="font-mono text-slate-400" title="' +
              escapeHtml(String(f.run_id != null ? f.run_id : "")) +
              '">' +
              escapeHtml(ridShort) +
              "</span>";
            html += "</div></article>";
          }
          html += "</div></section>";
        }
        listEl.innerHTML = html;
        loadMoreBtn.classList.toggle("hidden", !hasMore);
      }

      function escapeHtml(s) {
        return String(s)
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;");
      }

      async function fetchPage() {
        if (!baseUrl) {
          allFindings = [];
          hasMore = false;
          render();
          return;
        }
        if (loading) return;
        loading = true;
        loadMoreBtn.disabled = true;
        try {
          var qs =
            "limit=" +
            encodeURIComponent(String(pageSize)) +
            "&offset=" +
            encodeURIComponent(String(nextOffset));
          var res = await fetch(baseUrl + "/v1/evaluations?" + qs, { cache: "no-store" });
          if (!res.ok) {
            allFindings = [];
            hasMore = false;
            render();
            return;
          }
          var json = await res.json();
          var chunk = json && json.data;
          if (!Array.isArray(chunk)) chunk = [];
          for (var i = 0; i < chunk.length; i++) allFindings.push(chunk[i]);
          hasMore = chunk.length === pageSize;
          nextOffset += chunk.length;
          buildRepoButtons(allFindings);
          buildDimensionButtons(allFindings);
        } catch (e) {
          allFindings = [];
          hasMore = false;
        }
        loading = false;
        loadMoreBtn.disabled = false;
        render();
      }

      var sevWrap = root.querySelector("[data-severity-buttons]");
      var repoWrap = root.querySelector("[data-repo-buttons]");
      var dimWrap = root.querySelector("[data-dimension-buttons]");
      var sourceWrap = root.querySelector("[data-source-buttons]");
      if (sevWrap) {
        sevWrap.addEventListener("click", function (e) {
          var t = e.target;
          if (t.tagName !== "BUTTON") return;
          var v = t.getAttribute("data-severity");
          selectedSeverity = v == null ? "" : v;
          setButtonGroup(sevWrap, "data-severity", selectedSeverity);
          render();
        });
      }
      if (dimWrap) {
        dimWrap.addEventListener("click", function (e) {
          var t = e.target;
          if (t.tagName !== "BUTTON") return;
          var v = t.getAttribute("data-dimension");
          selectedDimension = v == null ? "" : v;
          setButtonGroup(dimWrap, "data-dimension", selectedDimension);
          render();
        });
      }
      if (sourceWrap) {
        sourceWrap.addEventListener("click", function (e) {
          var t = e.target;
          if (t.tagName !== "BUTTON") return;
          var v = t.getAttribute("data-source");
          selectedSource = v == null ? "" : v;
          setButtonGroup(sourceWrap, "data-source", selectedSource);
          render();
        });
      }
      if (repoWrap) {
        repoWrap.addEventListener("click", function (e) {
          var t = e.target;
          if (t.tagName !== "BUTTON") return;
          var v = t.getAttribute("data-repo");
          selectedRepo = v == null ? "" : v;
          setButtonGroup(repoWrap, "data-repo", selectedRepo);
          render();
        });
      }

      loadMoreBtn.addEventListener("click", function () {
        void fetchPage();
      });

      void fetchPage();
    })();
  </script>
</Page>
