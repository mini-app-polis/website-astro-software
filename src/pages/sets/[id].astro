---
import Page from "../../layouts/Page.astro";
import TrackTable from "../../components/TrackTable.astro";
import { getSetDetail } from "../../lib/api";

export const prerender = false;

const { id } = Astro.params;
const set = await getSetDetail(String(id));
console.log("[set detail] tracks:", set?.tracks?.length);

if (!set) {
  return Astro.redirect("/sets");
}

const dateFmt = new Intl.DateTimeFormat("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
});

const subtitle = `${set.tracks.length} tracks`;
---

<Page title={set.venue} subtitle={subtitle}>
  <div class="space-y-4">
    <a
      href="/sets"
      class="inline-flex items-center gap-2 text-sm font-medium text-slate-200 transition-colors hover:text-accent"
    >
      <span aria-hidden="true" class="font-mono">
        ←
      </span>
      Set History
    </a>

    <div class="text-sm text-slate-400">
      <span class="font-mono text-slate-200">{dateFmt.format(new Date(set.set_date))}</span>
    </div>

    <TrackTable tracks={set.tracks} />
  </div>
</Page>

