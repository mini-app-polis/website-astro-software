---
import Base from "../layouts/Base.astro";
import EvaluationSummary from "../components/EvaluationSummary.astro";
---

<Base title="Kaiano Levine — Software Engineer">
  <section class="space-y-10 pb-4 pt-2">
    <div class="space-y-5">
      <h1 class="font-display text-5xl tracking-tight sm:text-6xl">
        Kaiano Levine
      </h1>
      <div class="flex flex-wrap items-baseline gap-3">
        <h2 class="font-display text-2xl tracking-tight text-slate-100">
          Software Engineer
        </h2>
        <p class="max-w-2xl text-sm text-slate-400">
          I build data pipelines, automation systems, and AI-integrated APIs.
          This site is powered by one of them.
        </p>
      </div>
    </div>

    <div class="grid gap-5 md:grid-cols-3 items-stretch">
      <!-- Ecosystem -->
      <a
        href="/ecosystem"
        class="group flex flex-col justify-between rounded-2xl border border-violet-500/20 bg-violet-500/5 p-5 transition-colors hover:border-violet-500/40"
      >
        <div class="space-y-2">
          <div class="flex items-center justify-between gap-2">
            <span class="font-display text-base tracking-tight text-slate-100">Ecosystem</span>
            <span class="rounded-full border border-white/10 bg-white/5 px-2 py-0.5 font-mono text-xs text-slate-400">
              Active
            </span>
          </div>
          <p class="text-sm leading-relaxed text-slate-400">
            Five active services — cogs, a shared library, a FastAPI, and two sites — all
            running on Railway and Cloudflare Pages. Every service built to the same standards.
          </p>
        </div>
        <div class="pt-4 font-mono text-xs text-violet-400 transition-colors group-hover:text-violet-300">
          View service map ↗
        </div>
      </a>

      <!-- Standards -->
      <a
        href="/standards"
        class="group flex flex-col justify-between rounded-2xl border border-emerald-500/20 bg-emerald-500/5 p-5 transition-colors hover:border-emerald-500/40"
      >
        <div class="space-y-2">
          <div class="flex items-center justify-between gap-2">
            <span class="font-display text-base tracking-tight text-slate-100">
              Engineering Standards
            </span>
            <span class="rounded-full border border-white/10 bg-white/5 px-2 py-0.5 font-mono text-xs text-slate-400">
              v1.6.0
            </span>
          </div>
          <p class="text-sm leading-relaxed text-slate-400">
            A machine-readable spec — 100+ rules across structure, testing, documentation, and
            delivery — that drives automated conformance checks after every pipeline run.
          </p>
        </div>
        <div class="pt-4 font-mono text-xs text-emerald-400 transition-colors group-hover:text-emerald-300">
          Browse rules ↗
        </div>
      </a>

      <!-- Pipeline Health -->
      <a
        href="/pipeline"
        class="group flex flex-col justify-between rounded-2xl border border-amber-500/20 bg-amber-500/5 p-5 transition-colors hover:border-amber-500/40"
      >
        <div class="space-y-2">
          <div class="flex items-center justify-between gap-2">
            <span class="font-display text-base tracking-tight text-slate-100">Pipeline Health</span>
            <span class="rounded-full border border-white/10 bg-white/5 px-2 py-0.5 font-mono text-xs text-slate-400">
              Live
            </span>
          </div>
          <p class="text-sm leading-relaxed text-slate-400">
            After every pipeline run, Claude evaluates each service against the standards doc.
            Findings are stored in PostgreSQL and surfaced here in real time.
          </p>
        </div>
        <div class="pt-4 font-mono text-xs text-amber-400 transition-colors group-hover:text-amber-300">
          View live findings ↗
        </div>
      </a>
    </div>

    <div class="space-y-4 rounded-2xl border border-white/10 bg-white/[0.02] p-6 shadow-soft">
      <div class="space-y-1">
        <h2 class="font-display text-base tracking-tight text-slate-100">
          Live System Health
        </h2>
        <p class="text-sm text-slate-400">
          AI conformance checks run against every service after each pipeline execution.
        </p>
      </div>
      <EvaluationSummary />
      <div class="flex items-center justify-between">
        <a
          href="/flags"
          class="inline-flex items-center gap-2 font-mono text-sm text-slate-400 transition-colors hover:text-slate-100"
        >
          Feature flags ↗
        </a>
        <a
          href="/pipeline"
          class="inline-flex items-center gap-2 font-mono text-sm text-slate-400 transition-colors hover:text-slate-100"
        >
          Full findings ↗
        </a>
      </div>
    </div>

    <div class="rounded-2xl border border-white/10 bg-white/[0.02] p-6 shadow-soft">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div class="space-y-1">
          <h2 class="font-display text-base tracking-tight text-slate-100">
            Music Data
          </h2>
          <p class="text-sm text-slate-400">
            Full set history, live plays, stats, and playlists live on the WCS site.
          </p>
        </div>
        <a
          href="https://wcs.kaianolevine.com/dj-marvel"
          target="_blank"
          rel="noreferrer"
          class="inline-flex items-center gap-2 rounded-full border border-white/10 px-5 py-2 font-mono text-sm text-slate-200 transition-colors hover:border-white/20 hover:text-slate-100"
        >
          wcs.kaianolevine.com
          <span aria-hidden="true">↗</span>
        </a>
      </div>
    </div>
  </section>
</Base>

