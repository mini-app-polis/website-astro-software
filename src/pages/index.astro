---
import Base from "../layouts/Base.astro";
import StatsBar from "../components/StatsBar.astro";
import ProjectCard from "../components/ProjectCard.astro";
import EvaluationSummary from "../components/EvaluationSummary.astro";
import RecentFindings from "../components/RecentFindings.astro";
import FeatureFlags from "../components/FeatureFlags.astro";

const projects = [
  {
    title: "DJ Sets Platform",
    description:
      "CSV exports from DJ software → deejay-cog normalization pipeline → api-kaianolevine-com REST API. 10 years of set history in PostgreSQL, served live.",
    status: "Live",
    link: "https://github.com/mini-app-polis/deejay-cog",
  },
  {
    title: "Automation Ecosystem",
    description:
      "Python cogs on shared utilities (common-python-utils): watcher-cog polls Drive, deejay-cog ingests sets, evaluator-cog runs AI conformance checks after every pipeline run.",
    status: "Active",
    link: "https://github.com/mini-app-polis",
  },
  {
    title: "AI Pipeline Evaluation",
    description:
      "After every pipeline run, Claude evaluates conformance against the ecosystem standards document. Findings stored in PostgreSQL and queryable via API. See Pipeline Health for live data.",
    status: "Live",
    link: "/pipeline",
    linkLabel: "Pipeline Health",
  },
] as const;
---

<Base title="Kaiano Levine — Software Engineer">
  <section class="space-y-10 pb-4 pt-2">
    <div class="space-y-5">
      <h1 class="font-display text-5xl tracking-tight sm:text-6xl">
        Kaiano Levine
      </h1>
      <div class="flex flex-wrap items-baseline gap-3">
        <h2 class="font-display text-2xl tracking-tight text-slate-100">
          Software Engineer
        </h2>
        <p class="max-w-2xl text-sm text-slate-400">
          I build data pipelines, automation systems, and AI-integrated APIs.
          This site is powered by one of them.
        </p>
      </div>
    </div>

    <StatsBar />

    <div class="grid gap-5 md:grid-cols-3 items-stretch">
      {projects.map((p) => (
        <div class="h-full">
          <ProjectCard {...p} />
        </div>
      ))}
    </div>

    <div class="space-y-4">
      <h2 class="font-display text-xl tracking-tight">
        Live System Health
      </h2>
      <p class="text-sm text-slate-400">
        Every pipeline run is evaluated by Claude against the
        engineering standards document. Findings are stored and
        surfaced here in real time.
      </p>
      <EvaluationSummary />
      <RecentFindings />
      <FeatureFlags />
    </div>
  </section>
</Base>

