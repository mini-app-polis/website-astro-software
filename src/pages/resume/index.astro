---
import Page from "../../layouts/Page.astro";

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? "";
const apiBase = import.meta.env.PUBLIC_API_URL ?? "";
const resumeHref = apiBase ? `${apiBase.replace(/\/$/, "")}/v1/resume` : "#";
---

<Page title="Resume" subtitle="Verified access via Cloudflare Turnstile.">
  <section class="mt-2 space-y-5">
    <p class="text-sm text-slate-400">
      This resume is protected to prevent automated scraping. Complete the
      verification to reveal the PDF.
    </p>

    <div class="rounded-2xl border border-white/10 bg-white/[0.02] p-6 shadow-soft">
      <div
        class="cf-turnstile"
        data-sitekey={turnstileSiteKey}
        data-callback="onTurnstileVerified"
        data-action="resume_view"
      />

      <div id="resumeContent" class="hidden space-y-4">
        <p class="text-sm text-slate-400">
          Verification complete. Click below to open the resume.
        </p>
        <a
          id="resumeLink"
          href={resumeHref}
          target="_blank"
          rel="noreferrer"
          class="inline-flex items-center gap-2 rounded-full bg-accent px-6 py-3 font-mono text-sm font-semibold text-black transition-opacity hover:opacity-90"
        >
          Open Resume PDF
          <span aria-hidden="true">↗</span>
        </a>
      </div>
    </div>
  </section>

  <script
    src="https://challenges.cloudflare.com/turnstile/v0/api.js"
    async
    defer
  ></script>

  <script>
    function onTurnstileVerified(_token: string) {
      const content = document.getElementById("resumeContent");
      if (!content) return;
      content.classList.remove("hidden");
    }

    window.onTurnstileVerified = onTurnstileVerified;
  </script>
</Page>
